####################################
# User-generated project data (default: projects/ under repo root)
#
# Override with CLEAVE_DATA=~/.local/share/cleave for XDG layout (see cleave/paths.py).
projects/*
!projects/.gitkeep


####################################
# Project Ignores
#

# python
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
*.pyz
.pytest_cache/

# venv
venv/
.venv/
cleave-env/

# scratch / local temp
tmp/
tmp.txt